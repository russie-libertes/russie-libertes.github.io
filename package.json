{
  "name": "blog",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "changeorg": "python changeorg.py -i ./content/main/changeorg.md -o ./content/scrape/changeorg.json",
    "media": "python media.py     -i ./content/main/media.md     -o ./content/scrape/media.json",
    "helloasso": "python helloasso.py -c ./content/site.config.json  -o ./content/scrape/helloasso.json --scrape",
    "instagram": "python instagram.py -c ./content/site.config.json  -o ./content/scrape/instagram.json --image-dir ./public/instagram",
    "googlecalendar": "python googlecalendar.py -c ./content/site.config.json -o ./content/scrape/googlecalendar.json",
    "buildnocache": "rm -rf .astro node_modules/.astro || true; astro build",
    "devnocache": "rm -rf .astro node_modules/.astro || true; astro dev"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.14",
    "@astrojs/sitemap": "^3.6.0",
    "@rollup/plugin-yaml": "^4.1.2",
    "@sveltia/cms": "^0.149.1",
    "@tailwindcss/vite": "^4.1.17",
    "astro": "^5.16.4",
    "remark": "^15.0.1",
    "tailwindcss": "^4.1.17",
    "unist-util-visit": "^5.0.0"
  }
}
