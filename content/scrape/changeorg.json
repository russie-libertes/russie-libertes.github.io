  {
    "title": "Pétition · Prosecute Putin's regime's crimes under international law. - Lettonie · Change.org",
    "meta": {
      "viewport": "width=device-width, initial-scale=1.0",
      "og:site_name": "Change.org",
      "og:ttl": "2419200",
