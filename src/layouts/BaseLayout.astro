---
import { getCollection, render } from 'astro:content';
import {getBaseUrlWithTrailingSlash, getCurrentLocale, getMarkdownEntryForLocale} from '../scripts/utils.js';

import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Head from "../components/Head.astro";
import CookieConsentBox from "../components/CookieConsentBox.astro";

const currentLocale = getCurrentLocale(Astro);

const main = await getCollection('main');
const CookieConsentBoxMarkdown = await render(getMarkdownEntryForLocale(main, currentLocale, 'cookieconsentbox.md'))

const {pageTitle} = Astro.props;

const siteurl = Astro.site;
const baseurl = getBaseUrlWithTrailingSlash();

const openGraph = {
	basic : {
		title : pageTitle,
		type: "website",
		image: "",
		url: Astro.url.href
	}
};
---

<html lang={currentLocale}>
	<Head pageTitle={pageTitle} openGraph={openGraph} siteurl={siteurl} baseurl={baseurl} />

	<body>

		<div class="header-container">
			<Header />
		</div>
		
		<slot />
		
		<div class="footer-container">
			<Footer />
		</div>

		<!--
		<div class="cookieconsentbox-container">
			<CookieConsentBox>
				<CookieConsentBoxMarkdown.Content />
			</CookieConentBox>
		</div>
		-->
	</body>
</html>
