---

import { formatDateTime, getCurrentLocale, excerpt, isProd } from '../scripts/utils.js';
import googlecalendar_events from '../../content/scrape/googlecalendar.json';
import facebook_events from '../../content/scrape/facebookevents.json';

function formatMapsLink(location)
{
    if(!location)
        return '';
    const google_maps_prefix = 'https://www.google.com/maps/search/?api=1&query=';
    const query = location.split().join('+');
    const url = google_maps_prefix + query;
    return url;
}

function formatIcsFileName(dtstart_iso)
{
    if(!dtstart_iso)
        return 'default.ics';
    return dtstart_iso.replaceAll(':', '-').replaceAll('.', '-') + '.ics';
}

function isPast(dtstart_iso, now = new Date())
{
    if(!dtstart_iso)
        return false;
    const withoutTime = dt => dt.setHours(0,0,0,0);
    return withoutTime(new Date(dtstart_iso)) < withoutTime(now);
}

const currentLocale = getCurrentLocale(Astro);
const { googlecalendar_id, future, past, auto, embed, subscribe, now } = Astro.props;
const googlecalendar_embed_url     = `https://calendar.google.com/calendar/embed?src=${googlecalendar_id}`;
const googlecalendar_subscribe_url = `https://calendar.google.com/calendar/r?cid=${googlecalendar_id}`;

const events_joined = googlecalendar_events.map(e => ({...e, past : isPast(e.dtstart_iso)}));
const past_events   = events_joined.filter(e =>  e.past);
const future_events = events_joined.filter(e => !e.past);
const events = auto ? (future_events.length > 0 ? future_events : past_events) : (!past && future) ? future_events : (past && !future) ? past_events : [];

---

<div class="card-grid">
{events.map(e => (
    <article class="card">
        { e.past ? (
            <h2 class="card-title">{e.summary}</h2>
        ) : (
        <a download={formatIcsFileName(e.dtstart_iso)} href={e.ical_str ? ("data:text/calendar," + encodeURIComponent(e.ical_str)) : null}>
            <h2 class="card-title">{e.summary}</h2>
        </a>
        )}
        <div class="card-meta">
            <time datetime={e.dtstart_iso}>{e.dtstart_iso}<!-- formatDateTime(e.evt.startDate.toJSDate(), currentLocale)--></time>
            <a href={formatMapsLink(e.location)}>
                <address>{e.location}</address>
            </a>
        </div>
        <blockquote class="card-excerpt">{excerpt(e.description)}<blockquote/>
    </article>
))}
</div>
{events.length == 0 && (<p><slot /></p>)}

{!embed && subscribe && (
<div style="display:flex; margin-top:1em">
<a style="margin:auto" href={googlecalendar_subscribe_url} class="link-button" target="_blank">Add to Google Calendar</a>
</div>
)}

{(embed && isProd()) ? (
<iframe  style="border: 0" width="100%" height="600" frameborder="0" scrolling="no" src={googlecalendar_embed_url}></iframe>
) : embed ? (
<p>Not displaying Google Calendar embed in development to avoid bans</p>
) : (<p></p>)
}
